{
  "id": "helitehas-tallinn",
  "domain": "helitehas.ee",
  "url": "https://helitehas.ee/en/",
  "type": "static_selectors",
  "selectors": {
    "eventBlock": "div.archive-event:has(.event_address:contains('Helitehas'))",
